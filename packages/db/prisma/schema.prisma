// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────
// TENANT & SUBSCRIPTION
// ─────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  domains      TenantDomain[]
  branding     TenantBranding?
  subscription Subscription?
  featureFlags FeatureFlag[]
  users        User[]
  memberships  Membership[]
  roles        Role[]
  orders       Order[]
  products     Product[]
  warehouses   Warehouse[]
  couriers     CourierAccount[]
  wallets      Wallet[]
  commissionRules CommissionRule[]
  notificationConfigs NotificationConfig[]
  brands       Brand[]
  auditLogs    AuditLog[]
  coupons      Coupon[]
  roleAutomations RoleAutomation[]

  @@index([slug])
}

model TenantDomain {
  id        String   @id @default(uuid())
  tenantId  String
  domain    String   @unique
  isActive  Boolean  @default(true)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([domain])
  @@index([tenantId])
}

model TenantBranding {
  id           String  @id @default(uuid())
  tenantId     String  @unique
  companyName  String
  primaryColor String  @default("#000000")
  logoUrl      String?
  faviconUrl   String?
  emailHeader  String?
  customCss    String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Plan {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  priceMonthly Decimal @db.Decimal(10,2)
  priceYearly  Decimal @db.Decimal(10,2)
  maxUsers     Int     @default(5)
  maxOrders    Int     @default(500)
  maxProducts  Int     @default(100)
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())

  subscriptions Subscription[]
}

model Subscription {
  id         String             @id @default(uuid())
  tenantId   String             @unique
  planId     String
  status     SubscriptionStatus @default(ACTIVE)
  billingCycle BillingCycle     @default(MONTHLY)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelledAt        DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id])

  @@index([tenantId])
}

model FeatureFlag {
  id       String  @id @default(uuid())
  tenantId String
  feature  String
  enabled  Boolean @default(false)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, feature])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────
// USERS & ACCESS
// ─────────────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  tenantId      String
  email         String
  name          String
  passwordHash  String
  phone         String?
  avatarUrl     String?
  emailVerifiedAt DateTime?
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships Membership[]
  orders      Order[]      @relation("OrderCreatedBy")
  ownedOrders     Order[]      @relation("OrderOwner")
  ownedProducts   Product[]    @relation("ProductOwner")
  ownedWarehouses Warehouse[]  @relation("WarehouseOwner")
  ownedInvoices   Invoice[]    @relation("InvoiceOwner")
  wallet      Wallet?
  auditLogs   AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
}

model Membership {
  id       String @id @default(uuid())
  tenantId String
  userId   String
  roleId   String
  level    Int    @default(1)
  uplineId String?
  joinedAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id])

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@index([uplineId])
}

model Role {
  id          String  @id @default(uuid())
  tenantId    String
  name        String
  level       Int     @default(1)
  permissions Json    @default("[]")
  isDefault   Boolean @default(false)
  createdAt   DateTime @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships Membership[]
  automations RoleAutomation[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────
// PRODUCTS & INVENTORY
// ─────────────────────────────────────────────────────────

model Product {
  id          String  @id @default(uuid())
  tenantId    String
  ownerId     String?
  brandId     String?
  sku         String
  name        String
  description String?
  categoryId  String?
  status      ProductStatus @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner      User?             @relation("ProductOwner", fields: [ownerId], references: [id])
  brand      Brand?            @relation(fields: [brandId], references: [id])
  variations ProductVariation[]
  orderItems OrderItem[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([ownerId])
}

model ProductVariation {
  id        String  @id @default(uuid())
  productId String
  sku       String  @unique
  name      String
  price     Decimal @db.Decimal(10,2)
  weight    Decimal @db.Decimal(8,3)
  imageUrl  String?

  product        Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  stocks         ProductStock[]
  stockMovements StockMovement[]
  orderItems     OrderItem[]

  @@index([productId])
  @@index([sku])
}

model Warehouse {
  id       String @id @default(uuid())
  tenantId String
  ownerId  String?
  name     String
  address  String?
  isDefault Boolean @default(false)

  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner  User?          @relation("WarehouseOwner", fields: [ownerId], references: [id])
  stocks ProductStock[]

  @@index([tenantId])
  @@index([ownerId])
}

model ProductStock {
  id          String @id @default(uuid())
  variationId String
  warehouseId String
  quantity    Int    @default(0)
  reserved    Int    @default(0)

  variation ProductVariation @relation(fields: [variationId], references: [id], onDelete: Cascade)
  warehouse Warehouse        @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([variationId, warehouseId])
}

model StockMovement {
  id          String            @id @default(uuid())
  variationId String
  quantity    Int
  type        StockMovementType
  referenceId String?
  note        String?
  createdAt   DateTime          @default(now())
  createdBy   String?

  variation ProductVariation @relation(fields: [variationId], references: [id])

  @@index([variationId])
}

// ─────────────────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────────────────

model Order {
  id            String      @id @default(uuid())
  tenantId      String
  ownerId       String?
  orderNo       String
  brandId       String?
  customerId    String?
  customerName  String
  customerPhone String
  customerEmail String?
  shippingAddress Json
  status        OrderStatus @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)
  subtotal      Decimal     @db.Decimal(10,2)
  shippingFee   Decimal     @db.Decimal(10,2) @default(0)
  discount      Decimal     @db.Decimal(10,2) @default(0)
  total         Decimal     @db.Decimal(10,2)
  notes         String?
  createdById   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner     User?       @relation("OrderOwner", fields: [ownerId], references: [id])
  brand     Brand?      @relation(fields: [brandId], references: [id])
  createdBy User?       @relation("OrderCreatedBy", fields: [createdById], references: [id])
  items        OrderItem[]
  shipment     OrderShipment?
  payments     OrderPayment[]
  invoices     Invoice[]
  couponUsages CouponUsage[]

  @@unique([tenantId, orderNo])
  @@index([tenantId])
  @@index([ownerId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  productId   String
  variationId String
  sku         String
  name        String
  quantity    Int
  unitPrice   Decimal @db.Decimal(10,2)
  totalPrice  Decimal @db.Decimal(10,2)

  order     Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product          @relation(fields: [productId], references: [id])
  variation ProductVariation @relation(fields: [variationId], references: [id])

  @@index([orderId])
}

model OrderShipment {
  id          String          @id @default(uuid())
  orderId     String          @unique
  courierId   String?
  awbNo       String?
  trackingUrl String?
  status      ShipmentStatus  @default(PENDING)
  labelUrl    String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([awbNo])
}

model OrderPayment {
  id            String        @id @default(uuid())
  orderId       String
  amount        Decimal       @db.Decimal(10,2)
  method        String
  status        PaymentStatus @default(UNPAID)
  gatewayRef    String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Invoice {
  id         String      @id @default(uuid())
  tenantId   String
  ownerId    String?
  orderId    String
  type       InvoiceType
  invoiceNo  String
  pdfUrl     String?
  createdAt  DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id])
  owner User? @relation("InvoiceOwner", fields: [ownerId], references: [id])

  @@unique([tenantId, invoiceNo])
  @@index([orderId])
  @@index([ownerId])
}

// ─────────────────────────────────────────────────────────
// COURIER ACCOUNTS
// ─────────────────────────────────────────────────────────

model CourierAccount {
  id         String  @id @default(uuid())
  tenantId   String
  provider   CourierProvider
  label      String
  credentials Json
  isActive   Boolean @default(true)
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────
// WALLET & COMMISSION
// ─────────────────────────────────────────────────────────

model Wallet {
  id        String  @id @default(uuid())
  tenantId  String
  userId    String  @unique
  balance   Decimal @db.Decimal(12,2) @default(0)
  holdBalance Decimal @db.Decimal(12,2) @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@index([tenantId])
}

model WalletTransaction {
  id          String              @id @default(uuid())
  walletId    String
  type        WalletTransactionType
  amount      Decimal             @db.Decimal(12,2)
  balanceBefore Decimal           @db.Decimal(12,2)
  balanceAfter  Decimal           @db.Decimal(12,2)
  referenceId String?
  note        String?
  createdAt   DateTime            @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([createdAt])
}

model CommissionRule {
  id         String         @id @default(uuid())
  tenantId   String
  type       CommissionType
  name       String
  value      Decimal        @db.Decimal(8,4)
  valueType  CommissionValueType @default(PERCENTAGE)
  minLevel   Int?
  maxLevel   Int?
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────
// BRANDS
// ─────────────────────────────────────────────────────────

model Brand {
  id       String @id @default(uuid())
  tenantId String
  name     String
  logoUrl  String?
  settings Json?
  isActive Boolean @default(true)
  createdAt DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]
  orders   Order[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────────────────

model NotificationConfig {
  id       String              @id @default(uuid())
  tenantId String
  channel  NotificationChannel
  settings Json
  isActive Boolean             @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, channel])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String?
  action     String
  entity     String
  entityId   String?
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum ShipmentStatus {
  PENDING
  BOOKED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
  RETURNED
}

enum InvoiceType {
  SELLER
  CUSTOMER
  DELIVERY_NOTE
}

enum StockMovementType {
  IN
  OUT
  RESERVED
  RELEASED
  ADJUSTMENT
}

enum CourierProvider {
  NINJAVAN
  POS_MALAYSIA
  JNT
  DHL
  FLASH
  GDEX
  SKYNET
  AIRPAK
  OTHERS
}

enum WalletTransactionType {
  CREDIT
  DEBIT
  COMMISSION
  WITHDRAWAL
  REFUND
  TRANSFER_IN
  TRANSFER_OUT
}

enum CommissionType {
  SALES
  RECRUITMENT
  CHANNEL
  NETWORK
  POINT
  SAME_LEVEL
  BONUS
}

enum CommissionValueType {
  PERCENTAGE
  FIXED
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP_OFFICIAL
  WHATSAPP_UNOFFICIAL
  WEBHOOK
}

// ─────────────────────────────────────────────────────────
// COUPON
// ─────────────────────────────────────────────────────────

model Coupon {
  id              String      @id @default(uuid())
  tenantId        String
  code            String
  type            CouponType  @default(PERCENTAGE)
  value           Decimal     @db.Decimal(10,2)
  minOrderAmount  Decimal?    @db.Decimal(10,2)
  maxDiscount     Decimal?    @db.Decimal(10,2)
  usageLimit      Int?
  usedCount       Int         @default(0)
  startsAt        DateTime?
  expiresAt       DateTime?
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usages  CouponUsage[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model CouponUsage {
  id        String   @id @default(uuid())
  couponId  String
  orderId   String
  userId    String?
  discount  Decimal  @db.Decimal(10,2)
  usedAt    DateTime @default(now())

  coupon  Coupon  @relation(fields: [couponId], references: [id], onDelete: Cascade)
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([couponId, orderId])
  @@index([couponId])
}

// ─────────────────────────────────────────────────────────
// ROLE AUTOMATION
// ─────────────────────────────────────────────────────────

model RoleAutomation {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  trigger   String
  condition Json     @default("{}")
  roleId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

enum CouponType {
  PERCENTAGE
  FIXED
}
